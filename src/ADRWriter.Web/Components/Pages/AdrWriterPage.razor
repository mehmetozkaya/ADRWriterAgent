@page "/adr-writer"
@rendermode InteractiveServer

@using ADRWriter.Web.ApiClients
@using Markdig

@inject ADRWriterApiClient ADRWriterApi

<PageTitle>ADR Writer</PageTitle>

<div class="adr-chat-container d-flex flex-column" style="height: calc(100vh - 130px);">
    <h3 class="mb-3">
        <span class="bi bi-pencil-square-fill me-2"></span>ADR Writer Agent
    </h3>
    <p class="text-muted small mb-3">
        Describe the architectural decision you need to document, and the AI agent will generate a complete ADR for you.
    </p>

    @* Chat messages area *@
    <div class="flex-grow-1 overflow-auto border rounded p-3 mb-3 bg-light" id="chat-area" style="min-height: 200px;">
        @if (_messages.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <h5>Welcome to ADR Writer</h5>
                <p>Describe your architectural decision context to get started.</p>
                <p class="small">
                    <strong>Example:</strong> <em>"We need to decide between PostgreSQL and MongoDB for our product catalog microservice
                    that handles complex queries at 10K req/min."</em>
                </p>
            </div>
        }

        @foreach (var message in _messages)
        {
            <div class="mb-3 @(message.IsUser ? "text-end" : "")">
                <div class="d-inline-block px-3 py-2 rounded-3 @(message.IsUser ? "bg-primary text-white" : "bg-white border")"
                     style="max-width: 85%; text-align: left;">
                    <div class="fw-semibold small mb-1">
                        @(message.IsUser ? "You" : "ADR Writer Agent")
                    </div>
                    @if (message.IsUser)
                    {
                        <div style="white-space: pre-wrap;">@message.Content</div>
                    }
                    else
                    {
                        <div class="markdown-content">@((MarkupString)RenderMarkdown(message.Content))</div>
                    }
                </div>
            </div>
        }

        @if (_isStreaming)
        {
            <div class="mb-3">
                <div class="d-inline-block px-3 py-2 rounded-3 bg-white border" style="max-width: 85%; text-align: left;">
                    <div class="fw-semibold small mb-1">ADR Writer Agent</div>
                    <div class="markdown-content">@((MarkupString)RenderMarkdown(_streamingContent))</div>
                    <span class="streaming-cursor">▌</span>
                </div>
            </div>
        }
    </div>

    @* Input area *@
    <div class="input-group">
        <textarea class="form-control" rows="3"
                  placeholder="Describe the architectural decision you need to document..."
                  @bind="_userInput"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  disabled="@_isStreaming"></textarea>
        <button class="btn btn-primary d-flex align-items-center px-4"
                @onclick="SendMessageAsync"
                disabled="@(_isStreaming || string.IsNullOrWhiteSpace(_userInput))">
            @if (_isStreaming)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                <span>Generating…</span>
            }
            else
            {
                <span>Send</span>
            }
        </button>
    </div>
</div>

<style>
    .streaming-cursor {
        animation: blink 1s step-end infinite;
        color: #0d6efd;
    }

    @@keyframes blink {
        50% { opacity: 0; }
    }

    .markdown-content h1 { font-size: 1.4rem; margin-top: 0.5rem; }
    .markdown-content h2 { font-size: 1.2rem; margin-top: 0.5rem; }
    .markdown-content h3 { font-size: 1.1rem; margin-top: 0.5rem; }
    .markdown-content pre { background: #f4f4f4; padding: 0.75rem; border-radius: 0.375rem; overflow-x: auto; }
    .markdown-content code { font-size: 0.875em; }
    .markdown-content table { width: 100%; margin-bottom: 1rem; }
    .markdown-content table th,
    .markdown-content table td { border: 1px solid #dee2e6; padding: 0.4rem 0.6rem; }
    .markdown-content table th { background: #f8f9fa; }
    .markdown-content ul, .markdown-content ol { padding-left: 1.5rem; }
</style>

@code {
    private string _userInput = string.Empty;
    private string _streamingContent = string.Empty;
    private bool _isStreaming;
    private readonly List<ChatMessage> _messages = [];
    private CancellationTokenSource? _cts;

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private static string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrEmpty(markdown))
            return string.Empty;

        return Markdown.ToHtml(markdown, MarkdownPipeline);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", CtrlKey: true } && !_isStreaming && !string.IsNullOrWhiteSpace(_userInput))
        {
            await SendMessageAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(_userInput) || _isStreaming)
            return;

        var context = _userInput.Trim();
        _userInput = string.Empty;

        _messages.Add(new ChatMessage(context, IsUser: true));
        _isStreaming = true;
        _streamingContent = string.Empty;

        StateHasChanged();

        _cts = new CancellationTokenSource();

        try
        {
            await foreach (var chunk in ADRWriterApi.WriteADRStreamingAsync(context, _cts.Token))
            {
                _streamingContent += chunk;
                StateHasChanged();
            }

            _messages.Add(new ChatMessage(_streamingContent, IsUser: false));
        }
        catch (OperationCanceledException)
        {
            if (!string.IsNullOrEmpty(_streamingContent))
            {
                _messages.Add(new ChatMessage(_streamingContent + "\n\n*[Generation cancelled]*", IsUser: false));
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage($"Error: {ex.Message}", IsUser: false));
        }
        finally
        {
            _isStreaming = false;
            _streamingContent = string.Empty;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private record ChatMessage(string Content, bool IsUser);
}
